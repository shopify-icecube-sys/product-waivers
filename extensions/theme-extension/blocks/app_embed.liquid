<!-- Product Waivers App Embed -->

{% comment %} Pass product metafield, app URL and shop domain to JS {% endcomment %}
{% if product %}
  <script>
    window.__pwRequiresWaiver = {{ product.metafields.custom.requires_race_waiver.value | json | default: 'false' }};
    window.__pwProductHandle  = {{ product.handle | json }};
    window.__pwShop           = {{ shop.permanent_domain | json }};
  </script>
{% else %}
  <script>
    window.__pwRequiresWaiver = false;
    window.__pwProductHandle  = null;
    window.__pwShop           = {{ shop.permanent_domain | json }};
  </script>
{% endif %}

<!-- Waiver Modal HTML -->
<div id="pw-waiver-modal" aria-modal="true" role="dialog" aria-labelledby="pw-waiver-title" style="display:none;">
  <div id="pw-waiver-backdrop"></div>
  <div id="pw-waiver-box">
    <button id="pw-waiver-close" aria-label="Close">&times;</button>
    <div id="pw-waiver-content">

      <h2 id="pw-waiver-title">Competition / Racing Use Verification Form</h2>
      <p class="pw-subtitle">Required for non-CARB EO and non-EPA certified products.</p>

      <!-- Progress Indicator -->
      <div class="pw-progress">
        <div class="pw-prog-step pw-prog-active" data-n="1">1</div>
        <div class="pw-prog-line"></div>
        <div class="pw-prog-step" data-n="2">2</div>
        <div class="pw-prog-line"></div>
        <div class="pw-prog-step" data-n="3">3</div>
        <div class="pw-prog-line"></div>
        <div class="pw-prog-step" data-n="4">4</div>
        <div class="pw-prog-line"></div>
        <div class="pw-prog-step" data-n="5">5</div>
      </div>

      <!-- Step 1: Customer Information -->
      <div class="pw-panel" id="pw-panel-1">
        <h3 class="pw-step-title">Step 1 - Customer Information</h3>
        <div class="pw-row">
          <div class="pw-field">
            <label class="pw-label">Full Legal Name <span class="pw-req">*</span></label>
            <input class="pw-input" type="text" id="pw-full-name" placeholder="e.g. John Michael Doe">
            <span class="pw-err-msg" id="pw-err-full-name">This field is required.</span>
          </div>
          <div class="pw-field">
            <label class="pw-label">Email <span class="pw-req">*</span></label>
            <input class="pw-input" type="email" id="pw-email" placeholder="e.g. john@example.com">
            <span class="pw-err-msg" id="pw-err-email">This field is required.</span>
          </div>
        </div>
        <div class="pw-row">
          <div class="pw-field">
            <label class="pw-label">Phone <span class="pw-req">*</span></label>
            <input class="pw-input" type="tel" id="pw-phone" placeholder="e.g. (555) 555-5555">
            <span class="pw-err-msg" id="pw-err-phone">This field is required.</span>
          </div>
          <div class="pw-field">
            <label class="pw-label">Driver's License <span class="pw-req">*</span></label>
            <input class="pw-input" type="text" id="pw-license" placeholder="e.g. D1234567">
            <span class="pw-err-msg" id="pw-err-license">This field is required.</span>
          </div>
        </div>
        <div class="pw-row">
          <div class="pw-field pw-full">
            <label class="pw-label">Street Address <span class="pw-req">*</span></label>
            <input class="pw-input" type="text" id="pw-address" placeholder="e.g. 123 Main Street, Apt 4B">
            <span class="pw-err-msg" id="pw-err-address">This field is required.</span>
          </div>
        </div>
        <div class="pw-row">
          <div class="pw-field">
            <label class="pw-label">City <span class="pw-req">*</span></label>
            <input class="pw-input" type="text" id="pw-city" placeholder="e.g. Los Angeles">
            <span class="pw-err-msg" id="pw-err-city">This field is required.</span>
          </div>
          <div class="pw-field">
            <label class="pw-label">State <span class="pw-req">*</span></label>
            <select class="pw-select" id="pw-state">
              <option value="">Select State</option>
              <option>Alabama</option><option>Alaska</option><option>Arizona</option>
              <option>Arkansas</option><option>California</option><option>Colorado</option>
              <option>Connecticut</option><option>Delaware</option><option>Florida</option>
              <option>Georgia</option><option>Hawaii</option><option>Idaho</option>
              <option>Illinois</option><option>Indiana</option><option>Iowa</option>
              <option>Kansas</option><option>Kentucky</option><option>Louisiana</option>
              <option>Maine</option><option>Maryland</option><option>Massachusetts</option>
              <option>Michigan</option><option>Minnesota</option><option>Mississippi</option>
              <option>Missouri</option><option>Montana</option><option>Nebraska</option>
              <option>Nevada</option><option>New Hampshire</option><option>New Jersey</option>
              <option>New Mexico</option><option>New York</option><option>North Carolina</option>
              <option>North Dakota</option><option>Ohio</option><option>Oklahoma</option>
              <option>Oregon</option><option>Pennsylvania</option><option>Rhode Island</option>
              <option>South Carolina</option><option>South Dakota</option><option>Tennessee</option>
              <option>Texas</option><option>Utah</option><option>Vermont</option>
              <option>Virginia</option><option>Washington</option><option>West Virginia</option>
              <option>Wisconsin</option><option>Wyoming</option>
            </select>
            <span class="pw-err-msg" id="pw-err-state">Please select a state.</span>
          </div>
        </div>
        <div class="pw-row">
          <div class="pw-field">
            <label class="pw-label">ZIP <span class="pw-req">*</span></label>
            <input class="pw-input" type="text" id="pw-zip" placeholder="e.g. 90210 or 90210-1234">
            <span class="pw-err-msg" id="pw-err-zip">This field is required.</span>
          </div>
        </div>
        <div class="pw-row">
          <div class="pw-field pw-full">
            <label class="pw-label">Race Club / League Name</label>
            <input class="pw-input" type="text" id="pw-race-club" placeholder="e.g. Southern California Racing Club">
          </div>
        </div>
        <div class="pw-actions pw-actions-right">
          <button class="pw-btn pw-btn-primary" id="pw-next-1">Next</button>
        </div>
      </div>

      <!-- Step 2: Vehicle Information -->
      <div class="pw-panel pw-hidden" id="pw-panel-2">
        <h3 class="pw-step-title">Step 2 - Vehicle Information</h3>
        <div class="pw-row">
          <div class="pw-field">
            <label class="pw-label">Year <span class="pw-req">*</span></label>
            <select class="pw-select" id="pw-year">
              <option value="">Select Year</option>
            </select>
            <span class="pw-err-msg" id="pw-err-year">Please select a year.</span>
          </div>
          <div class="pw-field">
            <label class="pw-label">Make <span class="pw-req">*</span></label>
            <select class="pw-select" id="pw-make" disabled>
              <option value="">Select Make</option>
              <option>Acura</option>
              <option>Alfa Romeo</option>
              <option>Audi</option>
              <option>Bentley</option>
              <option>BMW</option>
              <option>Chevrolet</option>
              <option>Ferrari</option>
              <option>Ford</option>
              <option>Genesis</option>
              <option>Honda</option>
              <option>Hyundai</option>
              <option>Jaguar</option>
              <option>Jeep</option>
              <option>Kia</option>
              <option>Lamborghini</option>
              <option>Lexus</option>
              <option>Lincoln</option>
              <option>Lotus</option>
              <option>Maserati</option>
              <option>Mazda</option>
              <option>McLaren</option>
              <option>Mercedes-Benz</option>
              <option>Nissan</option>
              <option>Porsche</option>
              <option>Subaru</option>
              <option>Toyota</option>
            </select>
            <span class="pw-err-msg" id="pw-err-make">Please select a make.</span>
          </div>
        </div>
        <div class="pw-row">
          <div class="pw-field">
            <label class="pw-label">Model <span class="pw-req">*</span></label>
            <select class="pw-select" id="pw-model" disabled>
              <option value="">Select Model</option>
              <option>AVEO</option>
              <option>Beat</option>
              <option>CAMARO</option>
              <option>CAVALIER</option>
              <option>CITY EXPRESS</option>
              <option>COLORADO</option>
              <option>Corvette</option>
              <option>CRUZE</option>
              <option>EQUINOX</option>
              <option>EXPRESS</option>
              <option>IMPALA</option>
              <option>MALIBU</option>
              <option>S10</option>
              <option>SILVERADO</option>
              <option>SONIC</option>
              <option>SPARK</option>
              <option>SUBURBAN</option>
              <option>TAHOE</option>
              <option>TRAVERSE</option>
              <option>TRAX</option>
              <option>VOLT</option>
            </select>
            <span class="pw-err-msg" id="pw-err-model">Please select a model.</span>
          </div>
          <div class="pw-field">
            <label class="pw-label">Color <span class="pw-req">*</span></label>
            <select class="pw-select" id="pw-color">
              <option value="">Select Color</option>
              <option>Silver</option>
              <option>Bronze</option>
              <option>Gold</option>
            </select>
            <span class="pw-err-msg" id="pw-err-color">Please select a color.</span>
          </div>
        </div>
        <div class="pw-row">
          <div class="pw-field pw-full">
            <label class="pw-label">VIN <span class="pw-req">*</span></label>
            <input class="pw-input" type="text" id="pw-vin" placeholder="e.g. 1HGBH41JXMN109186">
            <span class="pw-err-msg" id="pw-err-vin">This field is required.</span>
          </div>
        </div>
        <div class="pw-row">
          <div class="pw-field">
            <label class="pw-label">DMV Registered?</label>
            <select class="pw-select" id="pw-dmv">
              <option value="">Select</option>
              <option>Yes</option>
              <option>No</option>
            </select>
          </div>
          <div class="pw-field">
            <label class="pw-label">Licensed for Public Road Use?</label>
            <select class="pw-select" id="pw-licensed">
              <option value="">Select</option>
              <option>Yes</option>
              <option>No</option>
            </select>
          </div>
        </div>
        <div class="pw-actions pw-actions-split">
          <button class="pw-btn pw-btn-secondary" id="pw-prev-2">Previous</button>
          <button class="pw-btn pw-btn-primary" id="pw-next-2">Next</button>
        </div>
      </div>

      <!-- Step 3: Documents (PDF only, max 10 MB) -->
      <div class="pw-panel pw-hidden" id="pw-panel-3">
        <h3 class="pw-step-title">Step 3 - Documents</h3>
        <p class="pw-doc-hint">PDF files only &bull; Max 10 MB per file</p>
        <div class="pw-doc-row">
          <label class="pw-doc-label">Vehicle on Trailer <span class="pw-req">*</span></label>
          <div class="pw-doc-wrap">
            <input type="file" id="pw-doc-trailer" class="pw-file-input" accept=".pdf,application/pdf">
            <span class="pw-err-msg" id="pw-err-doc-trailer">Please upload this document.</span>
          </div>
        </div>
        <div class="pw-doc-row">
          <label class="pw-doc-label">Proof of Non-Road Use <span class="pw-req">*</span></label>
          <div class="pw-doc-wrap">
            <input type="file" id="pw-doc-nonroad" class="pw-file-input" accept=".pdf,application/pdf">
            <span class="pw-err-msg" id="pw-err-doc-nonroad">Please upload this document.</span>
          </div>
        </div>
        <div class="pw-doc-row">
          <label class="pw-doc-label">Event Registration <span class="pw-req">*</span></label>
          <div class="pw-doc-wrap">
            <input type="file" id="pw-doc-event" class="pw-file-input" accept=".pdf,application/pdf">
            <span class="pw-err-msg" id="pw-err-doc-event">Please upload this document.</span>
          </div>
        </div>
        <div class="pw-doc-row">
          <label class="pw-doc-label">Racing Club Membership</label>
          <div class="pw-doc-wrap">
            <input type="file" id="pw-doc-club" class="pw-file-input" accept=".pdf,application/pdf">
            <span class="pw-err-msg" id="pw-err-doc-club"></span>
          </div>
        </div>
        <div class="pw-actions pw-actions-split">
          <button class="pw-btn pw-btn-secondary" id="pw-prev-3">Previous</button>
          <button class="pw-btn pw-btn-primary" id="pw-next-3">Next</button>
        </div>
      </div>

      <!-- Step 4: Compliance -->
      <div class="pw-panel pw-hidden" id="pw-panel-4">
        <h3 class="pw-step-title">Step 4 - Compliance</h3>
        <div class="pw-notice-box">
          <strong>Notice:</strong> Product is not CARB or EPA approved for highway use.
        </div>
        <div class="pw-compliance-item">
          <p class="pw-compliance-text">Product is for racing/off-road use only.</p>
          <div class="pw-radio-group">
            <label><input type="radio" name="pw-c1" value="yes"> Yes</label>
            <label><input type="radio" name="pw-c1" value="no"> No</label>
          </div>
          <span class="pw-err-msg" id="pw-err-c1">Please select an option.</span>
        </div>
        <div class="pw-compliance-item">
          <p class="pw-compliance-text">Vehicle is not operated on public roads.</p>
          <div class="pw-radio-group">
            <label><input type="radio" name="pw-c2" value="yes"> Yes</label>
            <label><input type="radio" name="pw-c2" value="no"> No</label>
          </div>
          <span class="pw-err-msg" id="pw-err-c2">Please select an option.</span>
        </div>
        <div class="pw-compliance-item">
          <p class="pw-compliance-text">I acknowledge product is not CARB approved.</p>
          <div class="pw-radio-group">
            <label><input type="radio" name="pw-c3" value="yes"> Yes</label>
            <label><input type="radio" name="pw-c3" value="no"> No</label>
          </div>
          <span class="pw-err-msg" id="pw-err-c3">Please select an option.</span>
        </div>
        <div class="pw-compliance-item">
          <p class="pw-compliance-text">I acknowledge product is not EPA certified.</p>
          <div class="pw-radio-group">
            <label><input type="radio" name="pw-c4" value="yes"> Yes</label>
            <label><input type="radio" name="pw-c4" value="no"> No</label>
          </div>
          <span class="pw-err-msg" id="pw-err-c4">Please select an option.</span>
        </div>
        <div class="pw-warning-box">
          Operating an uncertified or tampered vehicle on public highways may result in DMV registration issues, failed smog inspections and penalties up to $37,500 per violation.
        </div>
        <div class="pw-actions pw-actions-split">
          <button class="pw-btn pw-btn-secondary" id="pw-prev-4">Previous</button>
          <button class="pw-btn pw-btn-primary" id="pw-next-4">Next</button>
        </div>
      </div>

      <!-- Step 5: Signature & Final Certification -->
      <div class="pw-panel pw-hidden" id="pw-panel-5">
        <h3 class="pw-step-title">Step 5 - Signature &amp; Final Certification</h3>
        <div class="pw-row">
          <div class="pw-field">
            <label class="pw-label">Printed Name <span class="pw-req">*</span></label>
            <input class="pw-input" type="text" id="pw-printed-name" placeholder="e.g. John Michael Doe">
            <span class="pw-err-msg" id="pw-err-printed-name">This field is required.</span>
          </div>
          <div class="pw-field">
            <label class="pw-label">Date <span class="pw-req">*</span></label>
            <input class="pw-input" type="date" id="pw-date">
            <span class="pw-err-msg" id="pw-err-date">This field is required.</span>
          </div>
        </div>
        <div class="pw-row">
          <div class="pw-field pw-full">
            <label class="pw-label">Digital Signature <span class="pw-req">*</span></label>
            <div class="pw-sig-wrapper" id="pw-sig-wrapper">
              <canvas id="pw-sig-canvas"></canvas>
              <span class="pw-sig-hint" id="pw-sig-hint">Draw your signature here</span>
              <button type="button" class="pw-sig-clear-btn" id="pw-sig-clear">&#x2715; Clear Signature</button>
            </div>
            <span class="pw-err-msg" id="pw-err-signature">Please provide your digital signature.</span>
          </div>
        </div>
        <div class="pw-cert-item">
          <p class="pw-compliance-text">I understand this product is not CARB approved.</p>
          <div class="pw-radio-group">
            <label><input type="radio" name="pw-s1" value="yes"> Yes</label>
            <label><input type="radio" name="pw-s1" value="no"> No</label>
          </div>
          <span class="pw-err-msg" id="pw-err-s1">Please select an option.</span>
        </div>
        <div class="pw-cert-item">
          <p class="pw-compliance-text">I understand this product may not be EPA certified.</p>
          <div class="pw-radio-group">
            <label><input type="radio" name="pw-s2" value="yes"> Yes</label>
            <label><input type="radio" name="pw-s2" value="no"> No</label>
          </div>
          <span class="pw-err-msg" id="pw-err-s2">Please select an option.</span>
        </div>
        <div class="pw-cert-item">
          <p class="pw-compliance-text">I certify under penalty of perjury that this product will only be used for racing/off-road purposes.</p>
          <div class="pw-radio-group">
            <label><input type="radio" name="pw-s3" value="yes"> Yes</label>
            <label><input type="radio" name="pw-s3" value="no"> No</label>
          </div>
          <span class="pw-err-msg" id="pw-err-s3">Please select an option.</span>
        </div>
        <span class="pw-err-msg" id="pw-submit-error" style="margin-top:8px;"></span>
        <div class="pw-actions pw-actions-split">
          <button class="pw-btn pw-btn-secondary" id="pw-prev-5">Previous</button>
          <button class="pw-btn pw-btn-submit" id="pw-submit">Submit</button>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- Waiver Modal Styles -->
<style>
  #pw-waiver-modal {
    position: fixed;
    inset: 0;
    z-index: 999999;
    align-items: center;
    justify-content: center;
  }
  #pw-waiver-modal.pw-visible { display: flex !important; }
  #pw-waiver-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    animation: pw-fade-in 0.2s ease;
  }
  #pw-waiver-box {
    position: relative;
    background: #ffffff;
    border-radius: 16px;
    padding: 32px 40px 28px;
    max-width: 700px;
    width: 95%;
    max-height: 90vh;
    overflow-y: auto;
    text-align: left;
    box-shadow: 0 32px 80px rgba(0,0,0,0.22), 0 8px 24px rgba(0,0,0,0.12);
    animation: pw-slide-up 0.28s cubic-bezier(0.34,1.56,0.64,1);
    z-index: 1;
    box-sizing: border-box;
  }
  #pw-waiver-close {
    position: absolute;
    top: 14px; right: 18px;
    background: none; border: none;
    font-size: 24px; color: #aaa;
    cursor: pointer; line-height: 1;
    padding: 2px 8px; border-radius: 6px;
    transition: background 0.15s, color 0.15s; z-index: 2;
  }
  #pw-waiver-close:hover { background: #f0f0f0; color: #222; }

  #pw-waiver-title {
    font-size: 22px; font-weight: 700; color: #111;
    margin: 0 0 4px; padding-right: 32px;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }
  .pw-subtitle {
    font-size: 13px; color: #e05c00; margin: 0 0 20px;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }

  /* Progress */
  .pw-progress { display: flex; align-items: center; margin-bottom: 24px; }
  .pw-prog-step {
    width: 32px; height: 32px; border-radius: 50%;
    background: #d1d5db; color: #fff;
    font-size: 13px; font-weight: 600;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; transition: background 0.2s;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }
  .pw-prog-step.pw-prog-active, .pw-prog-step.pw-prog-done { background: #2563eb; }
  .pw-prog-line { flex: 1; height: 2px; background: #d1d5db; transition: background 0.2s; }
  .pw-prog-line.pw-prog-done { background: #2563eb; }

  /* Panels */
  .pw-panel { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
  .pw-hidden { display: none !important; }
  .pw-step-title { font-size: 16px; font-weight: 700; color: #111; margin: 0 0 16px; }

  /* Rows & fields */
  .pw-row { display: flex; gap: 16px; margin-bottom: 12px; }
  .pw-field { flex: 1; display: flex; flex-direction: column; min-width: 0; }
  .pw-field.pw-full { flex: 0 0 100%; width: 100%; }
  .pw-label { font-size: 13px; font-weight: 500; color: #374151; margin-bottom: 4px; }
  .pw-req { color: #dc2626; }
  .pw-input, .pw-select {
    height: 36px; padding: 0 10px;
    border: 1px solid #d1d5db; border-radius: 6px;
    font-size: 14px; color: #111; background: #fff;
    box-sizing: border-box; width: 100%; outline: none;
    transition: border-color 0.15s; font-family: inherit;
  }
  .pw-input:focus, .pw-select:focus { border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,0.12); }
  .pw-input.pw-error, .pw-select.pw-error { border-color: #dc2626; }
  .pw-select { appearance: auto; }
  .pw-input:disabled, .pw-select:disabled { background: #f3f4f6; color: #9ca3af; cursor: not-allowed; border-color: #e5e7eb; }

  /* Inline errors */
  .pw-err-msg { display: none; color: #dc2626; font-size: 12px; margin-top: 3px; font-family: inherit; }
  .pw-err-msg.pw-show { display: block; }

  /* Documents */
  .pw-doc-hint { font-size: 12px; color: #6b7280; margin: -8px 0 12px; }
  .pw-doc-row {
    display: flex; align-items: flex-start;
    border: 1px dashed #d1d5db; border-radius: 8px;
    padding: 12px 16px; margin-bottom: 10px; gap: 16px;
  }
  .pw-doc-label { font-size: 13px; font-weight: 600; color: #374151; min-width: 180px; flex-shrink: 0; padding-top: 2px; }
  .pw-doc-wrap { flex: 1; display: flex; flex-direction: column; }
  .pw-file-input { font-size: 13px; color: #374151; }

  /* Signature pad */
  .pw-sig-wrapper {
    border: 1px solid #d1d5db; border-radius: 6px;
    overflow: hidden; background: #fff; position: relative;
  }
  .pw-sig-wrapper.pw-error { border-color: #dc2626; }
  #pw-sig-canvas {
    display: block; width: 100%; height: 130px;
    cursor: crosshair; touch-action: none;
  }
  .pw-sig-hint {
    position: absolute; top: 46%; left: 50%;
    transform: translate(-50%, -50%);
    color: #d1d5db; font-size: 13px;
    pointer-events: none; user-select: none;
    font-family: inherit; white-space: nowrap;
  }
  .pw-sig-clear-btn {
    display: block; width: 100%; padding: 6px;
    background: #f9fafb; border: none;
    border-top: 1px solid #e5e7eb;
    font-size: 12px; color: #6b7280;
    cursor: pointer; text-align: center;
    font-family: inherit; transition: background 0.15s;
  }
  .pw-sig-clear-btn:hover { background: #f3f4f6; }

  /* Compliance / cert */
  .pw-compliance-item, .pw-cert-item {
    border: 1px solid #e5e7eb; border-radius: 8px;
    padding: 10px 14px; margin-bottom: 8px;
  }
  .pw-compliance-text { font-size: 13px; font-weight: 500; color: #111; margin: 0 0 6px; }
  .pw-radio-group { display: flex; gap: 16px; font-size: 13px; color: #374151; }
  .pw-radio-group label { display: flex; align-items: center; gap: 4px; cursor: pointer; }

  /* Notice / warning */
  .pw-notice-box {
    background: #eff6ff; border-left: 4px solid #2563eb;
    border-radius: 6px; padding: 10px 14px;
    font-size: 13px; color: #1e40af; margin-bottom: 12px;
  }
  .pw-warning-box {
    background: #fef2f2; border: 1px solid #fecaca;
    border-radius: 6px; padding: 10px 14px;
    font-size: 13px; color: #991b1b; margin-top: 12px;
  }

  /* Buttons */
  .pw-actions { margin-top: 20px; display: flex; }
  .pw-actions-right  { justify-content: flex-end; }
  .pw-actions-split  { justify-content: space-between; }
  .pw-btn {
    padding: 8px 20px; border-radius: 6px;
    font-size: 14px; font-weight: 500;
    cursor: pointer; border: none; font-family: inherit;
    transition: opacity 0.15s;
  }
  .pw-btn:hover { opacity: 0.88; }
  .pw-btn:disabled { opacity: 0.55; cursor: not-allowed; }
  .pw-btn-primary   { background: #2563eb; color: #fff; }
  .pw-btn-secondary { background: #f3f4f6; color: #374151; border: 1px solid #d1d5db; }
  .pw-btn-submit    { background: #16a34a; color: #fff; }

  @keyframes pw-fade-in { from { opacity:0; } to { opacity:1; } }
  @keyframes pw-slide-up {
    from { opacity:0; transform: translateY(28px) scale(0.96); }
    to   { opacity:1; transform: translateY(0)    scale(1);    }
  }
</style>

<!-- Waiver Script -->
<script>
(function () {
  'use strict';

  var modal    = document.getElementById('pw-waiver-modal');
  var closeBtn = document.getElementById('pw-waiver-close');
  var backdrop = document.getElementById('pw-waiver-backdrop');

  /* ── pending cart-add state ── */
  var pendingForm  = null;
  var pendingFetch = null;
  var pendingXhr   = null;

  /* ── show / hide ── */
  function showModal() {
    goToStep(1);
    modal.style.display = '';
    modal.classList.add('pw-visible');
    document.body.style.overflow = 'hidden';
  }
  function hideModal() {
    modal.classList.remove('pw-visible');
    modal.style.display = 'none';
    document.body.style.overflow = '';
  }

  function cancelAndClose() {
    pendingForm = null; pendingFetch = null; pendingXhr = null;
    hideModal();
  }
  closeBtn.addEventListener('click', cancelAndClose);
  backdrop.addEventListener('click', cancelAndClose);
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') cancelAndClose(); });

  /* ── waiver check ── */
  function requiresWaiver() {
    return window.__pwRequiresWaiver === true || window.__pwRequiresWaiver === 'true';
  }

  /* ── step navigation ── */
  function goToStep(n) {
    for (var i = 1; i <= 5; i++) {
      var p = document.getElementById('pw-panel-' + i);
      if (p) {
        if (i === n) p.classList.remove('pw-hidden');
        else         p.classList.add('pw-hidden');
      }
    }
    updateProgress(n);
    document.getElementById('pw-waiver-box').scrollTop = 0;
  }

  function updateProgress(active) {
    document.querySelectorAll('.pw-prog-step').forEach(function (s) {
      var n = parseInt(s.getAttribute('data-n'), 10);
      s.classList.remove('pw-prog-active', 'pw-prog-done');
      if (n === active)    s.classList.add('pw-prog-active');
      else if (n < active) s.classList.add('pw-prog-done');
    });
    document.querySelectorAll('.pw-prog-line').forEach(function (l, idx) {
      if (idx < active - 1) l.classList.add('pw-prog-done');
      else                   l.classList.remove('pw-prog-done');
    });
  }

  /* ── helpers ── */
  function val(id)       { return ((document.getElementById(id) || {}).value || '').trim(); }
  function checked(name) { return !!document.querySelector('input[name="' + name + '"]:checked'); }
  function getRadioVal(name) {
    var el = document.querySelector('input[name="' + name + '"]:checked');
    return el ? el.value : '';
  }
  function getFileName(id) {
    var el = document.getElementById(id);
    return el && el.files && el.files[0] ? el.files[0].name : '';
  }

  /* ── error display ── */
  function fieldErr(inputId, msg) {
    var input = document.getElementById(inputId);
    if (input) input.classList.add('pw-error');
    var span = document.getElementById('pw-err-' + inputId.slice(3));
    if (span) { span.textContent = msg; span.classList.add('pw-show'); }
  }
  function spanErr(errId, msg) {
    var span = document.getElementById(errId);
    if (span) { span.textContent = msg; span.classList.add('pw-show'); }
  }
  function clearFieldErr(inputId) {
    var input = document.getElementById(inputId);
    if (input) input.classList.remove('pw-error');
    var span = document.getElementById('pw-err-' + inputId.slice(3));
    if (span) span.classList.remove('pw-show');
  }
  function clearSpanErr(errId) {
    var span = document.getElementById(errId);
    if (span) span.classList.remove('pw-show');
  }
  function clearErrors() {
    document.querySelectorAll('.pw-error').forEach(function (el) { el.classList.remove('pw-error'); });
    document.querySelectorAll('.pw-err-msg.pw-show').forEach(function (el) { el.classList.remove('pw-show'); });
  }

  /* ── PDF file validation ── */
  var MAX_MB = 10;
  function validateFile(input, required) {
    if (!input || !input.files || input.files.length === 0) {
      return required ? 'required' : null;
    }
    var file = input.files[0];
    var isPdf = file.type === 'application/pdf' || file.name.toLowerCase().endsWith('.pdf');
    if (!isPdf)                           return 'type';
    if (file.size > MAX_MB * 1024 * 1024) return 'size';
    return null;
  }

  /* ── format patterns ── */
  var RE_NAME  = /^[A-Za-z\s'\-.]+$/;
  var RE_EMAIL = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;
  var RE_PHONE = /^(\+1[\s.\-]?)?\(?\d{3}\)?[\s.\-]?\d{3}[\s.\-]?\d{4}$/;
  var RE_ZIP   = /^\d{5}(-\d{4})?$/;

  /* ── step validation ── */
  function validateStep(n) {
    clearErrors();
    var ok = true;
    var v;

    if (n === 1) {
      v = val('pw-full-name');
      if (!v)                       { fieldErr('pw-full-name', 'This field is required.'); ok = false; }
      else if (!RE_NAME.test(v))    { fieldErr('pw-full-name', 'Please enter letters only (no numbers).'); ok = false; }

      v = val('pw-email');
      if (!v)                       { fieldErr('pw-email', 'This field is required.'); ok = false; }
      else if (!RE_EMAIL.test(v))   { fieldErr('pw-email', 'Please enter a valid email address.'); ok = false; }

      v = val('pw-phone');
      if (!v)                       { fieldErr('pw-phone', 'This field is required.'); ok = false; }
      else if (!RE_PHONE.test(v))   { fieldErr('pw-phone', 'Please enter a valid US phone number (e.g. (555) 555-5555).'); ok = false; }

      if (!val('pw-license')) { fieldErr('pw-license', 'This field is required.'); ok = false; }
      if (!val('pw-address')) { fieldErr('pw-address', 'This field is required.'); ok = false; }
      if (!val('pw-city'))    { fieldErr('pw-city',    'This field is required.'); ok = false; }
      if (!val('pw-state'))   { fieldErr('pw-state',   'Please select a state.');  ok = false; }

      v = val('pw-zip');
      if (!v)                       { fieldErr('pw-zip', 'This field is required.'); ok = false; }
      else if (!RE_ZIP.test(v))     { fieldErr('pw-zip', 'Please enter a valid US ZIP code (e.g. 90210).'); ok = false; }

    } else if (n === 2) {
      if (!val('pw-year'))  { fieldErr('pw-year',  'Please select a year.');  ok = false; }
      if (!val('pw-make'))  { fieldErr('pw-make',  'Please select a make.');  ok = false; }
      if (!val('pw-model')) { fieldErr('pw-model', 'Please select a model.'); ok = false; }
      if (!val('pw-color')) { fieldErr('pw-color', 'Please select a color.'); ok = false; }
      if (!val('pw-vin'))   { fieldErr('pw-vin',   'This field is required.'); ok = false; }

    } else if (n === 3) {
      var docFields = [
        { id: 'pw-doc-trailer', required: true  },
        { id: 'pw-doc-nonroad', required: true  },
        { id: 'pw-doc-event',   required: true  },
        { id: 'pw-doc-club',    required: false },
      ];
      docFields.forEach(function (f) {
        var input  = document.getElementById(f.id);
        var errId  = 'pw-err-' + f.id.slice(3);
        var result = validateFile(input, f.required);
        if      (result === 'required') { spanErr(errId, 'Please upload this document.');          ok = false; }
        else if (result === 'type')     { spanErr(errId, 'Only PDF files are accepted.');           ok = false; }
        else if (result === 'size')     { spanErr(errId, 'File must be under ' + MAX_MB + 'MB.');  ok = false; }
      });

    } else if (n === 4) {
      if (!checked('pw-c1')) { spanErr('pw-err-c1', 'Please select an option.'); ok = false; }
      if (!checked('pw-c2')) { spanErr('pw-err-c2', 'Please select an option.'); ok = false; }
      if (!checked('pw-c3')) { spanErr('pw-err-c3', 'Please select an option.'); ok = false; }
      if (!checked('pw-c4')) { spanErr('pw-err-c4', 'Please select an option.'); ok = false; }

    } else if (n === 5) {
      if (!val('pw-printed-name')) { fieldErr('pw-printed-name', 'This field is required.'); ok = false; }
      if (!val('pw-date'))         { fieldErr('pw-date',         'This field is required.'); ok = false; }

      /* Canvas signature */
      if (window.__pwSigEmpty !== false) {
        var wrapper = document.getElementById('pw-sig-wrapper');
        if (wrapper) wrapper.classList.add('pw-error');
        spanErr('pw-err-signature', 'Please provide your digital signature.');
        ok = false;
      }

      if (!checked('pw-s1')) { spanErr('pw-err-s1', 'Please select an option.'); ok = false; }
      if (!checked('pw-s2')) { spanErr('pw-err-s2', 'Please select an option.'); ok = false; }
      if (!checked('pw-s3')) { spanErr('pw-err-s3', 'Please select an option.'); ok = false; }
    }

    return ok;
  }

  /* ── collect all form data for API ── */
  /* Read a file input as a base64 data URL (returns a Promise) */
  function readFileAsBase64(id) {
    return new Promise(function (resolve) {
      var el = document.getElementById(id);
      if (!el || !el.files || !el.files[0]) { resolve(''); return; }
      var reader = new FileReader();
      reader.onload  = function (e) { resolve(e.target.result); };
      reader.onerror = function ()  { resolve(''); };
      reader.readAsDataURL(el.files[0]);
    });
  }

  /* Returns a Promise that resolves to the full form payload */
  function collectFormData() {
    return Promise.all([
      readFileAsBase64('pw-doc-trailer'),
      readFileAsBase64('pw-doc-nonroad'),
      readFileAsBase64('pw-doc-event'),
      readFileAsBase64('pw-doc-club'),
    ]).then(function (contents) {
      return {
        shop:              window.__pwShop          || '',
        productHandle:     window.__pwProductHandle || '',
        fullName:          val('pw-full-name'),
        email:             val('pw-email'),
        phone:             val('pw-phone'),
        driversLicense:    val('pw-license'),
        streetAddress:     val('pw-address'),
        city:              val('pw-city'),
        state:             val('pw-state'),
        zip:               val('pw-zip'),
        raceClub:          val('pw-race-club'),
        vehicleYear:       val('pw-year'),
        vehicleMake:       val('pw-make'),
        vehicleModel:      val('pw-model'),
        vehicleColor:      val('pw-color'),
        vin:               val('pw-vin'),
        dmvRegistered:     val('pw-dmv'),
        licensedForRoad:   val('pw-licensed'),
        docTrailerName:    getFileName('pw-doc-trailer'),
        docNonRoadName:    getFileName('pw-doc-nonroad'),
        docEventName:      getFileName('pw-doc-event'),
        docClubName:       getFileName('pw-doc-club'),
        docTrailerContent: contents[0],
        docNonRoadContent: contents[1],
        docEventContent:   contents[2],
        docClubContent:    contents[3],
        racingUseOnly:     getRadioVal('pw-c1'),
        notOnPublicRoads:  getRadioVal('pw-c2'),
        notCarbApproved:   getRadioVal('pw-c3'),
        notEpaCertified:   getRadioVal('pw-c4'),
        printedName:       val('pw-printed-name'),
        signatureDate:     val('pw-date'),
        digitalSignature:  window.__pwGetSignature ? window.__pwGetSignature() : '',
        certCarbApproved:  getRadioVal('pw-s1'),
        certEpaCertified:  getRadioVal('pw-s2'),
        certPerjury:       getRadioVal('pw-s3'),
      };
    });
  }

  /* ── step buttons ── */
  function bindStepButtons() {
    document.getElementById('pw-next-1').addEventListener('click', function () { if (validateStep(1)) goToStep(2); });
    document.getElementById('pw-prev-2').addEventListener('click', function () { goToStep(1); });
    document.getElementById('pw-next-2').addEventListener('click', function () { if (validateStep(2)) goToStep(3); });
    document.getElementById('pw-prev-3').addEventListener('click', function () { goToStep(2); });
    document.getElementById('pw-next-3').addEventListener('click', function () { if (validateStep(3)) goToStep(4); });
    document.getElementById('pw-prev-4').addEventListener('click', function () { goToStep(3); });
    document.getElementById('pw-next-4').addEventListener('click', function () { if (validateStep(4)) goToStep(5); });
    document.getElementById('pw-prev-5').addEventListener('click', function () { goToStep(4); });
    document.getElementById('pw-submit').addEventListener('click', handleSubmit);
  }

  /* ── form submission → save to DB → add to cart ── */
  function handleSubmit() {
    if (!validateStep(5)) return;

    var submitBtn = document.getElementById('pw-submit');
    var errEl     = document.getElementById('pw-submit-error');
    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Submitting…'; }
    if (errEl)     errEl.classList.remove('pw-show');

    /* App Proxy URL — same origin as storefront, no CORS needed */
    var apiUrl = '/apps/product-waivers/api/waiver';
    console.log('[Product Waivers] Submitting to:', apiUrl);

    collectFormData().then(function (data) {
      return fetch(apiUrl, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(data),
      });
    })
    .then(function (res) {
      if (!res.ok) throw new Error('Server error (' + res.status + ')');
      return res.json();
    })
    .then(function (result) {
      if (result.success) {
        hideModal();
        replayCartAdd();
      } else {
        console.error('[Product Waivers] Submission failed:', result.error);
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Submit'; }
        if (errEl) { errEl.textContent = 'Submission failed: ' + (result.error || 'please try again.'); errEl.classList.add('pw-show'); }
      }
    })
    .catch(function (err) {
      console.error('[Product Waivers] Error:', err.message, '| URL:', apiUrl);
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Submit'; }
      if (errEl) { errEl.textContent = 'Submission failed: ' + err.message + '. Please try again.'; errEl.classList.add('pw-show'); }
    });
  }

  /* ── live error clearing ── */
  function bindLiveValidation() {
    /* Step 1 */
    ['pw-full-name','pw-email','pw-phone','pw-license','pw-address','pw-city','pw-zip'].forEach(function (id) {
      var el = document.getElementById(id);
      if (el) el.addEventListener('input', function () { clearFieldErr(id); });
    });
    var stateEl = document.getElementById('pw-state');
    if (stateEl) stateEl.addEventListener('change', function () { clearFieldErr('pw-state'); });

    /* Step 2 – Year controls Make, Make controls Model */
    var yearSel   = document.getElementById('pw-year');
    var makeEl    = document.getElementById('pw-make');
    var modelEl   = document.getElementById('pw-model');

    if (yearSel) {
      yearSel.addEventListener('change', function () {
        clearFieldErr('pw-year');
        if (makeEl) {
          if (yearSel.value) {
            makeEl.disabled = false;
          } else {
            makeEl.disabled = true; makeEl.value = ''; clearFieldErr('pw-make');
            if (modelEl) { modelEl.disabled = true; modelEl.value = ''; clearFieldErr('pw-model'); }
          }
        }
      });
    }
    if (makeEl) {
      makeEl.addEventListener('change', function () {
        clearFieldErr('pw-make');
        if (modelEl) {
          if (makeEl.value) { modelEl.disabled = false; }
          else { modelEl.disabled = true; modelEl.value = ''; clearFieldErr('pw-model'); }
        }
      });
    }
    if (modelEl) modelEl.addEventListener('change', function () { clearFieldErr('pw-model'); });

    var colorEl = document.getElementById('pw-color');
    if (colorEl) colorEl.addEventListener('change', function () { clearFieldErr('pw-color'); });
    var vinEl = document.getElementById('pw-vin');
    if (vinEl) vinEl.addEventListener('input', function () { clearFieldErr('pw-vin'); });

    /* Step 3 – validate type & size on selection */
    ['pw-doc-trailer','pw-doc-nonroad','pw-doc-event'].forEach(function (id) {
      var el    = document.getElementById(id);
      var errId = 'pw-err-' + id.slice(3);
      if (el) {
        el.addEventListener('change', function () {
          var result = validateFile(el, true);
          if      (!result)               clearSpanErr(errId);
          else if (result === 'type')     spanErr(errId, 'Only PDF files are accepted.');
          else if (result === 'size')     spanErr(errId, 'File must be under ' + MAX_MB + 'MB.');
        });
      }
    });
    /* Optional club doc — only validate type/size if a file is chosen */
    var clubEl = document.getElementById('pw-doc-club');
    if (clubEl) {
      clubEl.addEventListener('change', function () {
        var result = validateFile(clubEl, false);
        if      (!result)             clearSpanErr('pw-err-doc-club');
        else if (result === 'type')   spanErr('pw-err-doc-club', 'Only PDF files are accepted.');
        else if (result === 'size')   spanErr('pw-err-doc-club', 'File must be under ' + MAX_MB + 'MB.');
      });
    }

    /* Step 4 radios */
    ['pw-c1','pw-c2','pw-c3','pw-c4'].forEach(function (name) {
      document.querySelectorAll('input[name="' + name + '"]').forEach(function (r) {
        r.addEventListener('change', function () { clearSpanErr('pw-err-' + name.slice(3)); });
      });
    });

    /* Step 5 */
    ['pw-printed-name','pw-date'].forEach(function (id) {
      var el = document.getElementById(id);
      if (el) el.addEventListener('input', function () { clearFieldErr(id); });
    });
    ['pw-s1','pw-s2','pw-s3'].forEach(function (name) {
      document.querySelectorAll('input[name="' + name + '"]').forEach(function (r) {
        r.addEventListener('change', function () { clearSpanErr('pw-err-' + name.slice(3)); });
      });
    });
  }

  /* ── canvas signature pad ── */
  function initSignaturePad() {
    var canvas  = document.getElementById('pw-sig-canvas');
    var hint    = document.getElementById('pw-sig-hint');
    var wrapper = document.getElementById('pw-sig-wrapper');
    if (!canvas) return;

    var ctx     = canvas.getContext('2d');
    var drawing = false;
    window.__pwSigEmpty = true;

    /* Fixed logical resolution — safe to set even while modal is hidden */
    canvas.width  = 600;
    canvas.height = 130;
    ctx.strokeStyle = '#111';
    ctx.lineWidth   = 2;
    ctx.lineCap     = 'round';
    ctx.lineJoin    = 'round';

    /* Scale mouse/touch coords from CSS pixels → canvas logical pixels */
    function getXY(e) {
      var rect   = canvas.getBoundingClientRect();
      var src    = e.touches ? e.touches[0] : e;
      var scaleX = canvas.width  / (rect.width  || canvas.width);
      var scaleY = canvas.height / (rect.height || canvas.height);
      return {
        x: (src.clientX - rect.left) * scaleX,
        y: (src.clientY - rect.top)  * scaleY,
      };
    }
    function onStart(e) {
      e.preventDefault(); drawing = true;
      var p = getXY(e); ctx.beginPath(); ctx.moveTo(p.x, p.y);
    }
    function onMove(e) {
      if (!drawing) return;
      e.preventDefault();
      var p = getXY(e); ctx.lineTo(p.x, p.y); ctx.stroke();
      if (window.__pwSigEmpty) {
        window.__pwSigEmpty = false;
        if (hint)    hint.style.display = 'none';
        if (wrapper) wrapper.classList.remove('pw-error');
        clearSpanErr('pw-err-signature');
      }
    }
    function onEnd() { drawing = false; }

    canvas.addEventListener('mousedown',  onStart);
    canvas.addEventListener('mousemove',  onMove);
    canvas.addEventListener('mouseup',    onEnd);
    canvas.addEventListener('mouseleave', onEnd);
    canvas.addEventListener('touchstart', onStart, { passive: false });
    canvas.addEventListener('touchmove',  onMove,  { passive: false });
    canvas.addEventListener('touchend',   onEnd);

    document.getElementById('pw-sig-clear').addEventListener('click', function () {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      window.__pwSigEmpty = true;
      if (hint) hint.style.display = '';
    });

    window.__pwGetSignature = function () {
      return window.__pwSigEmpty ? '' : canvas.toDataURL('image/png');
    };
  }

  /* ── populate Year dropdown 2026 → 1952 ── */
  function populateYears() {
    var sel = document.getElementById('pw-year');
    if (!sel) return;
    for (var y = 2026; y >= 1952; y--) {
      var opt = document.createElement('option');
      opt.value = String(y); opt.textContent = String(y);
      sel.appendChild(opt);
    }
  }

  /* ── cart-add replay after successful submission ── */
  function replayCartAdd() {
    if (pendingFetch) {
      var args = pendingFetch; pendingFetch = null;
      window.__pwWaiverDone = true;
      origFetch.apply(window, args).finally(function () { window.__pwWaiverDone = false; });
    } else if (pendingXhr) {
      var x = pendingXhr; pendingXhr = null;
      window.__pwWaiverDone = true;
      var xhr = new XMLHttpRequest();
      origXhrOpen.call(xhr, x.method, x.url);
      Object.keys(x.headers || {}).forEach(function (h) { xhr.setRequestHeader(h, x.headers[h]); });
      origXhrSend.call(xhr, x.body);
      window.__pwWaiverDone = false;
    } else if (pendingForm) {
      var f = pendingForm; pendingForm = null;
      window.__pwWaiverDone = true;
      f.submit();
      window.__pwWaiverDone = false;
    }
  }

  /* ── intercept form submits ── */
  function interceptForm(form) {
    if (form._pwDone) return;
    form._pwDone = true;
    form.addEventListener('submit', function (e) {
      if (window.__pwWaiverDone || !requiresWaiver()) return;
      e.preventDefault(); e.stopImmediatePropagation();
      pendingForm = form; pendingFetch = null; pendingXhr = null;
      showModal();
    }, true);
  }

  /* ── intercept fetch ── */
  var origFetch = window.fetch;
  (function patchFetch() {
    window.fetch = function () {
      var args = Array.prototype.slice.call(arguments);
      var req  = args[0];
      var url  = typeof req === 'string' ? req : (req && req.url) || '';
      if (/\/cart\/add/.test(url) && requiresWaiver() && !window.__pwWaiverDone) {
        pendingFetch = args; pendingForm = null; pendingXhr = null;
        showModal();
        return Promise.resolve(
          new Response(
            JSON.stringify({ status: 422, message: 'Waiver required.' }),
            { status: 422, headers: { 'Content-Type': 'application/json' } }
          )
        );
      }
      return origFetch.apply(window, args);
    };
  })();

  /* ── intercept XHR ── */
  var origXhrOpen = XMLHttpRequest.prototype.open;
  var origXhrSend = XMLHttpRequest.prototype.send;
  (function patchXHR() {
    XMLHttpRequest.prototype.open = function (method, url) {
      this._pwUrl = url || ''; this._pwMethod = method || '';
      return origXhrOpen.apply(this, arguments);
    };
    XMLHttpRequest.prototype.send = function (body) {
      if (/\/cart\/add/.test(this._pwUrl) && requiresWaiver() && !window.__pwWaiverDone) {
        pendingXhr = { method: this._pwMethod, url: this._pwUrl, body: body };
        pendingForm = null; pendingFetch = null;
        showModal(); return;
      }
      return origXhrSend.apply(this, arguments);
    };
  })();

  /* ── attach to add-to-cart forms ── */
  function attachToForms() {
    document.querySelectorAll('form[action*="/cart/add"]').forEach(interceptForm);
  }
  new MutationObserver(attachToForms)
    .observe(document.documentElement, { childList: true, subtree: true });

  /* ── init ── */
  function init() {
    populateYears();
    initSignaturePad();
    bindStepButtons();
    bindLiveValidation();
    attachToForms();
    console.log('[Product Waivers] Loaded. requires_waiver =', window.__pwRequiresWaiver);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

