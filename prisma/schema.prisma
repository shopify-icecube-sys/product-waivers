// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?

  @@index([shop])
}

model WaiverSubmission {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  shop             String
  productHandle    String

  // Step 1 – Customer Information
  fullName         String
  email            String
  phone            String
  driversLicense   String
  streetAddress    String
  city             String
  state            String
  zip              String
  raceClub         String?
  ipAddress        String?

  // Step 2 – Vehicle Information
  vehicleYear      String
  vehicleMake      String
  vehicleModel     String
  vehicleColor     String
  vin              String
  dmvRegistered    String?
  licensedForRoad  String?

  // Step 3 – Document file names + Shopify CDN URLs (or base64 for legacy entries)
  docTrailerName    String
  docNonRoadName    String
  docEventName      String
  docClubName       String?
  docTrailerUrl     String?  @map("docTrailerContent")
  docNonRoadUrl     String?  @map("docNonRoadContent")
  docEventUrl       String?  @map("docEventContent")
  docClubUrl        String?  @map("docClubContent")

  // Step 4 – Compliance
  racingUseOnly     String
  notOnPublicRoads  String
  notCarbApproved   String
  notEpaCertified   String

  // Step 5 – Signature & Certification
  printedName       String
  signatureDate     String
  digitalSignature  String  // base64 PNG/SVG data URL of the drawn signature
  certCarbApproved  String
  certEpaCertified  String
  certPerjury       String

  // Order-linked PDF
  orderNumber       String?
  orderGid          String?  // Shopify order GID stored by webhook (gid://shopify/Order/...)
  orderPdfUrl       String?

  @@index([shop])
  @@index([email])
}

model AppSetting {
  id            String   @id @default(cuid())
  shop          String   @unique
  buttonColor   String   @default("#2563eb")
  progressColor String   @default("#2563eb")
}

